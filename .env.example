# ─── LangSmith (required to see graphs in LangSmith Studio) ──────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=marketforge-ai
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── LLM ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/marketforge
REDIS_URL=redis://localhost:6379/0

# ─── MLflow ─────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── Scraping APIs ───────────────────────────────────────────────────────────
ADZUNA_APP_ID=xxxxxxxx
ADZUNA_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REED_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Email dispatch ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password
REPORT_RECIPIENT=your@email.com
